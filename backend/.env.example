# ── Alice Blue (Ant API) ───────────────────────────────────────────────────
ALICEBLUE_USER_ID=AB123456
ALICEBLUE_API_KEY=your_api_key_here

# ── Zerodha (optional) ─────────────────────────────────────────────────────
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_CLIENT_ID=

# ── Telegram notifications (optional) ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Database ───────────────────────────────────────────────────────────────
# On Render free tier, use SQLite (files are ephemeral — data lost on redeploy)
# For persistence, upgrade to a Render Postgres DB and set:
# DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname
DATABASE_URL=sqlite+aiosqlite:///./autotrade.db

# ── App ────────────────────────────────────────────────────────────────────
ENV=production
